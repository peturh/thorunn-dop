# Google Sheets integration for RSVPs
# Create a Google Cloud service account, enable the Google Sheets API,
# share your sheet with the service account email (Editor access),
# then fill in the values below.

# The ID from the sheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=

# Service account email (looks like: name@project-id.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# The "private_key" value from the downloaded service account JSON.
# Paste the full key including BEGIN/END lines. Newlines must be encoded as \n
# when stored as a single-line env var (e.g. on Vercel). Wrap in quotes.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional — defaults to "Sheet1!A:C" (timestamp, name, food).
# One row is appended per household member.
# GOOGLE_SHEET_RANGE=Sheet1!A:C

# Password gate for the RSVP form. If unset, the form is open to everyone.
# Leave commented out to disable.
RSVP_PASSWORD=thorunnsdop2026
